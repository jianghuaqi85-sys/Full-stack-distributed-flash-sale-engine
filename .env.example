# 应用配置
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=order_system
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME=300

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置（生产环境请使用强随机字符串）
JWT_SECRET=your_secure_secret_key
JWT_EXPIRE=86400

# OpenTelemetry 配置
OTEL_EXPORTER_TYPE=stdout
OTEL_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=order-system
